# Safe local-development defaults. Copy to .env; never commit real secrets.
APP_NAME=LearnStep
APP_ENV=development
APP_DEBUG=false
DATABASE_URL=postgresql+psycopg://classpath:classpath_dev@db:5432/classpath
POSTGRES_DB=classpath
POSTGRES_USER=classpath
POSTGRES_PASSWORD=classpath_dev
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:5173"]
DEMO_TOKEN_SECRET=local-demo-secret-change-before-deployment
DEMO_TOKEN_MINUTES=60
PRIVATE_DATA_ROOT=uploads
UPLOAD_MAX_BYTES=5000000
UPLOAD_MAX_PAGES=10
UPLOAD_MIN_TEXT_CHARS=40
DEMO_UPLOAD_TTL_MINUTES=60
